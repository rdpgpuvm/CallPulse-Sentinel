# CallModerator — Langfuse monitoring keys
# =========================================
# 1. Sign up free at https://langfuse.com
# 2. Create a project → Settings → API Keys
# 3. Copy this file to .env and fill in the values
# 4. The .env file is gitignored — never commit real keys

LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME

# Cloud endpoint (default — leave blank for langfuse.com cloud):
# LANGFUSE_HOST=https://cloud.langfuse.com

# Self-hosted endpoint (uncomment if running your own Langfuse):
# LANGFUSE_HOST=http://localhost:3000

# Optional: tag this deployment for filtering in the dashboard
LANGFUSE_RELEASE=call-moderator-v7
